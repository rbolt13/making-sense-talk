plot_top_terms <- function(model, n = 8) {
tidy(model, matrix = "beta") |>
group_by(topic) |>
slice_max(beta, n = n, with_ties = FALSE) |>
ungroup() |>
mutate(term = reorder_within(term, beta, topic)) |>
ggplot(aes(beta, term)) +
geom_col() +
facet_wrap(~ topic, scales = "free_y") +
scale_y_reordered() +
labs(
x = "Beta",
y = NULL,
title = "Top Terms by Topic"
)
}
plot_top_terms(model_elf, n = 8)
plot_top_terms(model_elf_bigrams, n = 8)
plot_top_terms(model_elf_trigrams, n = 8)
