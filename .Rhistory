plot_top_terms <- function(model, n = 8) {
tidy(model, matrix = "beta") |>
group_by(topic) |>
slice_max(beta, n = n, with_ties = FALSE) |>
ungroup() |>
mutate(
topic = paste("Topic", topic),
term = reorder_within(term, beta, topic)
) |>
ggplot(aes(beta, term, fill = topic)) +
geom_col(width = 0.75, show.legend = FALSE) +
facet_wrap(~ topic, scales = "free_y") +
scale_y_reordered() +
scale_x_continuous(
labels = scales::percent_format(accuracy = 0.1),
expand = expansion(mult = c(0, 0.08))
) +
scale_fill_manual(
values = c(
"#B22222", # christmas red
"#1B5E20", # evergreen
"#C9A227", # gold
"#0B3D2E", # dark green
"#8B0000", # deep red
"#D4AF37", # brighter gold
"#2E7D32", # green
"#7A1F1F"  # cranberry
)
) +
labs(
x = "Topic-word probability",
y = NULL,
title = "Top Terms by Topic",
subtitle = paste("Top", n, "terms with the highest beta value in each topic"),
caption = "Source: Movie review topic model"
) +
theme_minimal(base_size = 14) +
theme(
plot.title = element_text(
face = "bold",
size = 24,
color = "#7A1F1F"
),
plot.subtitle = element_text(
size = 13,
color = "#4A4A4A",
margin = margin(b = 12)
),
plot.caption = element_text(
size = 10,
color = "#666666",
hjust = 1
),
strip.text = element_text(
face = "bold",
size = 13,
color = "white"
),
strip.background = element_rect(
fill = "#0B3D2E",
color = NA
),
axis.text.y = element_text(
size = 11,
color = "#2B2B2B"
),
axis.text.x = element_text(
size = 10,
color = "#555555"
),
axis.title.x = element_text(
size = 11,
color = "#444444",
margin = margin(t = 8)
),
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank(),
panel.grid.major.x = element_line(
color = "#E6E6E6",
linewidth = 0.4
),
panel.spacing = unit(1.2, "lines"),
plot.background = element_rect(
fill = "#FFFDF7",
color = NA
),
panel.background = element_rect(
fill = "#FFFDF7",
color = NA
)
)
}
plot_top_terms(model_elf, n = 8)
