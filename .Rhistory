dogville_anti_american_summary <- dogville %>%
mutate(
text_clean = review_text %>%
str_to_lower() %>%
str_replace_all("[^a-z\\s]", " ") %>%
str_squish(),
mentions_anti_american = str_detect(text_clean, "anti american"),
references_review = str_detect(
text_clean,
"review|reviewer|critic|critics|criticism|article|claim|called|calling"
),
likely_agrees = str_detect(
text_clean,
"is anti american|was anti american|anti american film|anti american movie|clearly anti american"
),
likely_disagrees = str_detect(
text_clean,
"not anti american|isn t anti american|isnt anti american|not an anti american|anti american nonsense|so called anti american"
)
) %>%
filter(mentions_anti_american) %>%
summarise(
total_mentions = n(),
references_review = sum(references_review),
likely_agrees = sum(likely_agrees),
likely_disagrees = sum(likely_disagrees),
unclear = total_mentions - likely_agrees - likely_disagrees
)
dogville_anti_american_summary
dogville_anti_american_summary <- dogville %>%
mutate(
text_clean = review_text %>%
str_to_lower() %>%
str_replace_all("[^a-z\\s]", " ") %>%
str_squish(),
mentions_anti_american = str_detect(text_clean, "anti american"),
mentions_review_or_critic = str_detect(
text_clean,
"review|reviewer|critic|critics|criticism|article"
)
) %>%
filter(mentions_anti_american) %>%
summarise(
reviews_mentioning_anti_american = n(),
of_those_mentions_review_or_critic = sum(mentions_review_or_critic),
percent = of_those_mentions_review_or_critic / reviews_mentioning_anti_american
)
