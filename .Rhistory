library(tidyverse)
clean_text_data <- function(file_path, corpus) {
read_csv(file_path, show_col_types = FALSE) %>%
mutate(
corpus = corpus,
text = as.character(.[[1]]),
text_clean = text %>%
str_to_lower() %>%
str_replace_all("<br\\s*/?>", " ") %>%
str_replace_all("[^a-z\\s]", " ") %>%
str_squish()
)
}
