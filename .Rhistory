library(tidyverse)
dogville_topics <- tribble(
~topic, ~category, ~words,
1, "Critical reactions to pacing / length",
"minutes, boring, thought, got, time, hours, people, play",
2, "Grace, Tom, and the small-town plot",
"town, grace, small, bettany, paul, woman, tom, bacall",
3, "Human nature, morality, and power",
"human, nature, people, society, grace, power, life, humanity",
4, "Stage-like style, acting, and structure",
"story, acting, characters, stage, cast, theatre, set, unique",
5, "America / anti-American allegory",
"american, america, anti, americans, world, country, dancer, think"
) |>
separate_rows(words, sep = ", ") |>
group_by(topic, category) |>
mutate(rank = row_number()) |>
ungroup()
ggplot(
dogville_topics,
aes(
x = rank,
y = fct_rev(str_wrap(category, 30)),
fill = factor(topic)
)
) +
geom_tile(color = "white", linewidth = 1) +
geom_text(aes(label = words), color = "white", fontface = "bold", size = 4) +
scale_x_continuous(
breaks = 1:8,
labels = paste("Word", 1:8)
) +
scale_fill_manual(
values = c("#8E44AD", "#2980B9", "#16A085", "#F39C12", "#C0392B")
) +
labs(
title = "Dogville Review Topic Categories",
subtitle = "Top 8 words in each topic category",
x = NULL,
y = NULL,
fill = "Topic"
) +
theme_minimal(base_size = 14) +
theme(
panel.grid = element_blank(),
legend.position = "none",
plot.title = element_text(face = "bold"),
axis.text.y = element_text(face = "bold")
)
llibrary(tidyverse)
