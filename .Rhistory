stm_data <- function(clean_data, tokenize_data, rating) {
meta <- clean_data |>
distinct(row_id, {{ rating }}) |>
filter(!is.na({{ rating }})) |>
mutate(row_id = as.character(row_id))
tokenize_data <- tokenize_data |>
mutate(row_id = as.character(row_id)) |>
semi_join(meta, by = "row_id")
dtm <- tokenize_data |>
count(row_id, word) |>
cast_sparse(row_id, word, n)
meta <- meta |>
filter(row_id %in% rownames(dtm)) |>
arrange(match(row_id, rownames(dtm)))
dtm <- dtm[meta$row_id, , drop = FALSE]
corpus <- readCorpus(
as.matrix(dtm),
type = "dtm"
)
corpus$meta <- meta
corpus
}
model_data <- function(stm_data, k) {
stm(
documents = stm_data$documents,
vocab = stm_data$vocab,
K = k,
prevalence = ~ movie_review_score,
data = stm_data$meta
)
}
