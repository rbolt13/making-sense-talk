~topic, ~topic_name,
1, "Pacing / length",
2, "Small-town plot",
3, "Morality / power",
4, "Stage style / acting",
5, "America allegory"
)
top_terms <- tidy(model_dogville, matrix = "beta") |>
group_by(topic) |>
slice_max(beta, n = 8, with_ties = FALSE) |>
ungroup() |>
left_join(topic_names, by = "topic") |>
mutate(
topic_label = paste0("Topic ", topic, ": ", topic_name),
term = reorder_within(term, beta, topic_label)
)
