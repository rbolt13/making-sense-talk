term_frequencies_elf <- term_frequencies(tokenize_elf_bigram)
term_frequencies_elf_trigrams <- term_frequencies(tokenize_elf_trigrams)
# tokenize
tokenize_text <- function(clean_data, n = 1) {
clean_data |>
unnest_tokens(word, text_clean, token = "ngrams", n = n) |>
separate(
word,
into = paste0("word", 1:n),
sep = " ",
remove = FALSE
) |>
filter(if_all(all_of(paste0("word", 1:n)), ~ !.x %in% custom_stop_words$word)) |>
select(-all_of(paste0("word", 1:n)))
}
# frequencies
term_frequencies <- function(tokenize_data) {
tokenize_data |>
count(word, sort = TRUE)
}
clean_elf <- clean_text(elf, review_text)
tokenize_elf <- tokenize_text(clean_elf, n = 1)
tokenize_elf_bigrams <- tokenize_text(clean_elf, n = 2)
tokenize_elf_trigrams <- tokenize_text(clean_elf, n = 3)
term_frequencies_elf <- term_frequencies(tokenize_elf)
term_frequencies_elf_bigrams <- term_frequencies(tokenize_elf_bigrams)
term_frequencies_elf_trigrams <- term_frequencies(tokenize_elf_trigrams)
term_frequencies_elf
term_frequencies_elf_bigrams
term_frequencies_elf_trigrams
stm_data <- function(tokenize_data, rating) {
dtm <- tokenize_data |>
count(row_id, word) |>
cast_sparse(row_id, word, n)
meta <- tokenize_data |>
distinct(row_id, {{ rating }}) |>
mutate(row_id = as.character(row_id)) |>
filter(row_id %in% rownames(dtm)) |>
arrange(match(row_id, rownames(dtm)))
corpus <- readCorpus(
as.matrix(dtm),
type = "dtm"
)
corpus$meta <- meta
corpus
}
search_topics <- function(stm_data, k) {
searchK(
documents = stm_data$documents,
vocab = stm_data$vocab,
K = k,
prevalence = ~ movie_review_score,
data = stm_data$meta
)
}
stm_elf <- stm_data(tokenize_elf, movie_review_score)
search_k_elf <- search_topics(stm_elf, 2:10)
